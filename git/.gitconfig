[commit]
    gpgsign = true

[user]
    name = Norlan Perdomo
    email = norlan.perdomo@gmail.com
    signingkey = 79840D61

[includeIf "gitdir:~/code/"]
    path = ~/code/.gitconfig

[alias]
    ps = !git push origin $(git branch --show-current)
    pl = pull --recurse-submodules
    cm = !git add --all && git commit -m
    co = checkout 
    cob = checkout -b
    s = status
