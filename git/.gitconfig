[user]
    name = Norlan Perdomo
    email = norlan.perdomo@gmail.com

[includeIf "gitdir:~/code/"]
    path = ~/code/.gitconfig

[alias]
    ps = push origin $(git branch --show-current)
    pl = pull --recurse-submodules
    cm = !sh -c 'git add --all && git commit -m 1$' -
    co = checkout
    cob = checkout -b
    s = status
