[commit]
    gpgsign = true

[user]
    name = Norlan Perdomo
    email = norlan.perdomo@gmail.com
    signingkey = 79840D61

[includeIf "gitdir:~/code/"]
    path = ~/code/.gitconfig

[alias]
    ps = !git push origin $(git branch --show-current)
    pl = pull --recurse-submodules
    cm = !git add --all && git commit -m
    co = !"f() { git checkout $1 2>/dev/null || git checkout -b $1; }; f"
    cms = !"f() { git add --all && git commit -m $1 && git push origin $(git branch --show-current); }; f"
    s = status
[pull]
	rebase = false
[init]
	defaultBranch = master
