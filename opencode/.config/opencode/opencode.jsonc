{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "ollama-cloud/nemotron-3-nano:30b",
  "permission": {
    "read": {
      "~/.ssh/**": "deny",
      "**/.env*": "deny",
      "**/.env.example": "allow"
    },
    "edit": {
      "~/.ssh/**": "deny",
      "**/.env*": "deny",
      "**/.env.example": "allow"
    },
    "glob": {
      "~/.ssh/**": "deny",
      "**/.env*": "deny",
      "**/.env.example": "allow"
    },
    "grep": {
      "~/.ssh/**": "deny",
      "**/.env*": "deny",
      "**/.env.example": "allow"
    },
    "list": {
      "~/.ssh/**": "deny"
    }
  },
  "mcp": {
      "playwright": {
        "type": "local",
        "command": [
          "npx",
          "@playwright/mcp@latest",
          "--browser",
          "firefox"
        ],
        "enabled": true
      }
    },
  "snapshot": false
}
