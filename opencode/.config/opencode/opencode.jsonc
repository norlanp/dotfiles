{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "synthetic/hf:zai-org/GLM-4.7-Flash",
  "permission": {
    "read": {
      "~/.ssh/**": "deny",
      "**/.env*": "deny",
      "**/.env.example": "allow"
    },
    "edit": {
      "~/.ssh/**": "deny",
      "**/.env*": "deny",
      "**/.env.example": "allow"
    },
    "glob": {
      "~/.ssh/**": "deny",
      "**/.env*": "deny",
      "**/.env.example": "allow"
    },
    "grep": {
      "~/.ssh/**": "deny",
      "**/.env*": "deny",
      "**/.env.example": "allow"
    },
    "list": {
      "~/.ssh/**": "deny"
    }
  },
  "mode": {
      "t1": {
        "model": "openai/gpt-5.3-codex",
        "variant": "xhigh"
      },
      "t2": {
        "model": "openai/gpt-5.3-codex",
        "variant": "high"
      },
      "t3": {
        "model": "openai/gpt-5.3-codex",
        "variant": "medium"
      }
    },
  "mcp": {
      "playwright": {
        "type": "local",
        "command": [
          "npx",
          "@playwright/mcp@latest",
          "--browser",
          "firefox"
        ],
        "enabled": true
      }
    },
  "snapshot": false
}
